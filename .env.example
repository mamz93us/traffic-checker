APP_NAME="Traffic Checker"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Africa/Cairo

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=traffic_checker
DB_USERNAME=traffic_user
DB_PASSWORD=strong_password_here

# ── Cache / Queue ─────────────────────────────────────────────────
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Mail ─────────────────────────────────────────────────────────
# Recommended: SendGrid or Mailgun for production
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=your_sendgrid_api_key
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=violations@your-domain.com
MAIL_FROM_NAME="Traffic Violations Alert"

# ── WhatsApp (Green API) ──────────────────────────────────────────
# Sign up free at https://green-api.com — supports 2000 msgs/month free
# Alternative: Twilio, UltraMsg, WA Business API
WHATSAPP_PROVIDER=green_api
WHATSAPP_INSTANCE_ID=your_instance_id
WHATSAPP_ACCESS_TOKEN=your_access_token
# OR for Twilio:
# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your_sid
# TWILIO_AUTH_TOKEN=your_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Playwright / Chromium ─────────────────────────────────────────
# Path to playwright-installed chromium (run: npx playwright install chromium)
PLAYWRIGHT_CHROMIUM_PATH=/usr/bin/chromium-browser
# OR use Browsershot with puppeteer:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome

# Path to the Python checker script
PYTHON_SCRIPT_PATH=/var/www/traffic-checker/traffic_checker.py
PYTHON_BIN=/usr/bin/python3

# ── Screenshot Storage ────────────────────────────────────────────
SCREENSHOT_DISK=local
# For S3: change to s3 and fill credentials below
# SCREENSHOT_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=traffic-screenshots

# ── Check Schedule ────────────────────────────────────────────────
# How often to run automated checks (uses Laravel scheduler)
CHECK_FREQUENCY=daily    # daily | twice_daily | weekly
CHECK_TIME_1=08:00       # First check time (Cairo time)
CHECK_TIME_2=20:00       # Second check time (if twice_daily)

# ── Filament Admin ────────────────────────────────────────────────
FILAMENT_ADMIN_EMAIL=admin@your-domain.com
FILAMENT_ADMIN_PASSWORD=change_this_password
